# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=omni
DB_USER=omni
DB_PASSWORD=omni_password

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://127.0.0.1:3000

# Ollama (Local Primary)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma3:12b

# OpenRouter (Cloud Fallback) - Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3-haiku-20240307
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=OMNI Multi-Agent System

# Provider Settings
PROVIDER_PREFER_LOCAL=true
PROVIDER_FALLBACK_ON_ERROR=true

# Security
SECRET_KEY=your-secret-key-here

# GitHub (optional)
GITHUB_TOKEN=your_github_token

# Twitter (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# LinkedIn (optional)
LINKEDIN_ACCESS_TOKEN=your_linkedin_token

# System
LOG_LEVEL=INFO
ENVIRONMENT=development